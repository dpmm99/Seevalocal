<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Seevalocal.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Seevalocal.UI.Views.ResultsView">

  <UserControl.Styles>
    <Style Selector="TextBlock.copyable">
      <Setter Property="ContextMenu">
        <ContextMenu>
          <MenuItem Header="Copy" Click="CopyTextToClipboard"/>
        </ContextMenu>
      </Setter>
    </Style>
    <Style Selector="Expander.stageExpander">
      <Setter Property="Background" Value="#2A2A3E"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
    <Style Selector="Border.metricCard">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Margin" Value="0,4,4,4"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
      <TextBlock Text="Results Viewer" Classes="pageTitle"/>
      <Button Content="Load Results File" Classes="secondary" Padding="12,6" VerticalAlignment="Center"
              Command="{Binding $parent[Window].DataContext.LoadResultsFileCommand}"/>
    </StackPanel>

    <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,16">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
          <!-- Summary Cards -->
          <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,12">
            <Border Classes="reviewCard" Padding="16">
              <StackPanel>
                <TextBlock Text="Total Items" Classes="metricLabel"/>
                <TextBlock Text="{Binding CurrentResultsRun.TotalCount}" Classes="metricValue"/>
              </StackPanel>
            </Border>
            <Border Classes="reviewCard" Padding="16" Grid.Column="1">
              <StackPanel>
                <TextBlock Text="Completed" Classes="metricLabel"/>
                <TextBlock Text="{Binding CurrentResultsRun.CompletedCount}" Classes="metricValue"/>
              </StackPanel>
            </Border>
            <Border Classes="reviewCard" Padding="16" Grid.Column="2">
              <StackPanel>
                <TextBlock Text="Failed" Classes="metricLabel"/>
                <TextBlock Text="{Binding CurrentResultsRun.HadFailures, Converter={StaticResource BoolToYesNoConverter}}" Classes="metricValue"/>
              </StackPanel>
            </Border>
            <Border Classes="reviewCard" Padding="16" Grid.Column="3">
              <StackPanel>
                <TextBlock Text="Status" Classes="metricLabel"/>
                <TextBlock Text="{Binding CurrentResultsRun.StatusLine}" Classes="metricValue copyable"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Metric Statistics by Stage -->
          <Border Classes="reviewCard" Padding="16">
            <StackPanel>
              <TextBlock Text="Metric Statistics by Stage" Classes="sectionHeader" Margin="0,0,0,12"/>
              <TextBlock Text="No metrics available. Run an evaluation to see metric statistics." 
                         Foreground="#6C7086" FontStyle="Italic"
                         IsVisible="{Binding MetricStats.Count, Converter={x:Static converters:BoolNegationConverter.Instance}}"/>
              <ItemsControl ItemsSource="{Binding MetricStats}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Expander Classes="stageExpander" IsExpanded="{Binding IsExpanded}">
                      <Expander.Header>
                        <TextBlock Text="{Binding StageName}" FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                      </Expander.Header>
                      <Expander.Content>
                        <WrapPanel>
                          <ItemsControl ItemsSource="{Binding Metrics}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Classes="metricCard" MinWidth="180">
                                  <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding MetricName}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="#89B4FA" TextWrapping="Wrap"/>
                                    <StackPanel Spacing="2" Margin="0,4,0,0">
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Count:" FontSize="10" Foreground="#6C7086"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" FontSize="10" Foreground="#CDD6F4" 
                                                   HorizontalAlignment="Right"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Missing:" FontSize="10" Foreground="#6C7086"/>
                                        <TextBlock Grid.Column="1" Text="{Binding MissingCount}" FontSize="10" Foreground="#F38BA8" 
                                                   HorizontalAlignment="Right"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Min:" FontSize="10" Foreground="#6C7086"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Min, StringFormat={}{0:F2}}" FontSize="10" Foreground="#A6E3A1" 
                                                   HorizontalAlignment="Right"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Max:" FontSize="10" Foreground="#6C7086"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Max, StringFormat={}{0:F2}}" FontSize="10" Foreground="#F9E2AF" 
                                                   HorizontalAlignment="Right"/>
                                      </Grid>
                                      <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="Avg:" FontSize="10" Foreground="#6C7086"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Average, StringFormat={}{0:F2}}" FontSize="10" Foreground="#CDD6F4" 
                                                   HorizontalAlignment="Right"/>
                                      </Grid>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </WrapPanel>
                      </Expander.Content>
                    </Expander>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Results Table -->
          <Border Classes="reviewCard" Padding="16">
            <StackPanel>
              <TextBlock Text="Evaluation Results" Classes="sectionHeader" Margin="0,0,0,12"/>
              <DataGrid ItemsSource="{Binding CurrentResultsRun.Results}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        CanUserResizeColumns="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0"
                        Background="Transparent"
                        RowBackground="Transparent"
                        Height="400">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                  <DataGridTextColumn Header="Status" Binding="{Binding PipelineStatus}" Width="80"/>
                  <DataGridTextColumn Header="Prompt" Binding="{Binding UserPrompt}" Width="200"/>
                  <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedOutput}" Width="150"/>
                  <DataGridTextColumn Header="Score" Binding="{Binding JudgeScore, StringFormat=F1}" Width="80"/>
                  <DataGridTextColumn Header="Duration (s)" Binding="{Binding DurationSeconds, StringFormat=F2}" Width="100"/>
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
      <Button Content="Export Results JSON" Classes="secondary" Padding="16,8"
              Command="{Binding $parent[Window].DataContext.ExportResultsJsonCommand}"/>
      <Button Content="Export Shell Script" Classes="secondary" Padding="16,8"
              Command="{Binding $parent[Window].DataContext.ExportResultsShellScriptCommand}"/>
      <Button Content="Open Results Folder" Classes="primary" Padding="16,8"
              Command="{Binding $parent[Window].DataContext.OpenResultsFolderCommand}"/>
    </StackPanel>
  </Grid>
</UserControl>
