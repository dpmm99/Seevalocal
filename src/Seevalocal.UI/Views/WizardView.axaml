<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Seevalocal.UI.ViewModels"
             xmlns:local="using:Seevalocal.UI"
             xmlns:convert="using:Seevalocal.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Seevalocal.UI.Views.WizardView"
             x:DataType="vm:MainWindowViewModel">
  <UserControl.Resources>
    <convert:NullableValueConverter x:Key="NullableValue"/>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*,Auto" DataContext="{Binding WizardState}">
    <!-- Step Indicator - Only visible when this view is visible -->
    <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ContinueRun}}">
          <TextBlock Text="0"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Continue Run" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Resume from checkpoint" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PipelineSelection}}">
          <TextBlock Text="1"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Pipeline" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Select pipeline type" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ModelAndServer}}">
          <TextBlock Text="2"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Model &amp; Server" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Configure llama-server" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PerformanceSettings}}">
          <TextBlock Text="3"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Performance" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="GPU &amp; memory" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.EvaluationDataset}}">
          <TextBlock Text="4"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Dataset" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Evaluation data" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.FieldMapping}}">
          <TextBlock Text="5"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Field Mapping" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Map input fields" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.Scoring}}">
          <TextBlock Text="6"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Scoring" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="LLM-as-judge" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.Output}}">
          <TextBlock Text="7"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Output" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Results &amp; export" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PipelineConfiguration}}">
          <TextBlock Text="8"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Pipeline Config" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Pipeline options" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>

        <Border Classes="stepBadge" Classes.active="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ReviewAndRun}}">
          <TextBlock Text="9"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Review" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock Text="Confirm &amp; run" FontSize="10" Foreground="#7F849C"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Step Content - Scrollable -->
    <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="8" Padding="16">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <!-- Step 0: Continue Run -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ContinueRun}}">
            <TextBlock Text="Continue Existing Run" Classes="stepTitle"/>
            <TextBlock Text="Resume a previous evaluation run from a checkpoint database."
                       Classes="helpText" Margin="0,0,0,16"/>

            <Border Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="Checkpoint Database" Classes="sectionHeader"/>
                <TextBlock Text="Select the SQLite checkpoint database from a previous run to continue from where you left off."
                           Foreground="#7F849C" FontSize="12" TextWrapping="Wrap"/>

                <StackPanel Spacing="8" Margin="0,8">
                  <TextBlock Text="Database File" Classes="label"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding CheckpointDatabasePath}" Watermark="Select a checkpoint database file..."/>
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Padding="16,6"
                            Command="{Binding BrowseCheckpointDbCommand}"/>
                  </Grid>
                </StackPanel>

                <CheckBox Content="Continue from checkpoint" IsChecked="{Binding ContinueFromCheckpoint}" Margin="0,8"/>
                <TextBlock Text="When enabled, the run will resume from the last completed item in the checkpoint database."
                           Foreground="#7F849C" FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <Border Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="Reset Wizard" Classes="sectionHeader"/>
                <TextBlock Text="Reset all wizard fields to their default values. This will not affect settings loaded from files."
                           Foreground="#7F849C" FontSize="12" TextWrapping="Wrap"/>
                <Button Content="Reset Wizard to Defaults" HorizontalAlignment="Left" Padding="16,6"
                        Command="{Binding ResetToDefaultsCommand}"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 1: Model & Server -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ModelAndServer}}">
            <TextBlock Text="Model &amp; Server Configuration" Classes="stepTitle"/>
            <TextBlock Text="Choose how to run llama-server - either manage it locally or connect to an existing instance."
                       Classes="helpText" Margin="0,0,0,16"/>

            <StackPanel Spacing="12">
              <RadioButton Content="Manage llama-server locally"
                           IsChecked="{Binding ManageServer}"
                           GroupName="serverMode" Margin="0,4"/>
              <RadioButton Content="Connect to existing server"
                           IsChecked="{Binding ManageServer, Converter={x:Static convert:BoolNegationConverter.Instance}}"
                           GroupName="serverMode" Margin="0,4"/>
            </StackPanel>

            <Border IsVisible="{Binding ManageServer}" Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="llama-server Executable" Classes="sectionHeader"/>
                <TextBlock Text="Specify a local llama-server executable to use (optional). If not specified, the app will search for llama-server in standard locations."
                           Foreground="#7F849C" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0" Text="{Binding LlamaServerExecutablePath, UpdateSourceTrigger=PropertyChanged}" Watermark="Path to llama-server executable (optional)..."/>
                  <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Padding="16,6"
                          Command="{Binding BrowseLocalModelCommand}" CommandParameter="executable"/>
                </Grid>

                <Separator Background="#45475A" Margin="0,8"/>

                <TextBlock Text="Model Source" Classes="sectionHeader"/>
                <StackPanel Spacing="8">
                  <RadioButton Content="Local model file" IsChecked="{Binding UseLocalFile}" GroupName="modelSource"/>
                  <StackPanel IsVisible="{Binding UseLocalFile}" Margin="20,4,0,0" Spacing="8">
                    <TextBlock Text="Model File Path" Classes="label"/>
                    <TextBox Text="{Binding LocalModelPath}" Watermark="Select a .gguf model file..."/>
                    <Button Content="Browse..." HorizontalAlignment="Left" Padding="16,6"
                            Command="{Binding BrowseLocalModelCommand}"/>
                  </StackPanel>

                  <RadioButton Content="Download from HuggingFace" IsChecked="{Binding UseLocalFile, Converter={x:Static convert:BoolNegationConverter.Instance}}" GroupName="modelSource" Margin="0,8,0,0"/>
                  <StackPanel IsVisible="{Binding UseLocalFile, Converter={x:Static convert:BoolNegationConverter.Instance}}" Margin="20,4,0,0" Spacing="8">
                    <TextBlock Text="HuggingFace Repo" Classes="label"/>
                    <TextBox Text="{Binding HfRepo}" Watermark="e.g., TheBloke/Mistral-7B-Instruct-v0.1-GGUF"/>
                    <TextBlock Text="Quantization (optional)" Classes="label" Margin="0,8,0,0"/>
                    <TextBox Watermark="e.g., Q4_K_M (leave blank for default)"/>
                    <TextBlock Text="HuggingFace Token (optional)" Classes="label" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding HfToken}" Watermark="hf_..." PasswordChar="*"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding ManageServer, Converter={x:Static convert:BoolNegationConverter.Instance}}" Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Server Connection" Classes="sectionHeader"/>
                <TextBlock Text="Server URL" Classes="label"/>
                <TextBox Text="{Binding ServerUrl}" Watermark="http://127.0.0.1:8080"/>
                <Button Content="Test Connection" HorizontalAlignment="Left" Padding="16,6" Margin="0,8"
                        Command="{Binding TestConnectionCommand}"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 2: Performance Settings -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PerformanceSettings}}">
            <TextBlock Text="Performance Settings" Classes="stepTitle"/>
            <TextBlock Text="Configure llama-server options. Leave blank to use server defaults."
                       Classes="helpText" Margin="0,0,0,16"/>

            <!-- Context & Batching -->
            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Context &amp; Batching" Classes="sectionHeader"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,12">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Context Window (tokens)" Classes="label"/>
                    <TextBox Text="{Binding ContextWindowTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 4096"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Parallel Slots" Classes="label"/>
                    <TextBox Text="{Binding ParallelSlotCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 4"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Batch Size (tokens)" Classes="label"/>
                    <TextBox Text="{Binding BatchSizeTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 512"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Micro-Batch Size (tokens)" Classes="label"/>
                    <TextBox Text="{Binding UbatchSizeTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 64"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <CheckBox Content="Enable Continuous Batching" IsChecked="{Binding EnableContinuousBatching}"/>
                    <CheckBox Content="Cache Prompt Processing" IsChecked="{Binding EnableCachePrompt}"/>
                    <CheckBox Content="Enable Context Shift" IsChecked="{Binding EnableContextShift}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- GPU Settings -->
            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="GPU Acceleration" Classes="sectionHeader"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,12">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <TextBlock Text="GPU Layers" Classes="label"/>
                    <TextBox Text="{Binding GpuLayerCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 32"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Split Mode" Classes="label"/>
                    <ComboBox SelectedItem="{Binding SplitMode}" HorizontalAlignment="Left" MinWidth="150">
                      <ComboBoxItem Content="none"/>
                      <ComboBoxItem Content="layer"/>
                      <ComboBoxItem Content="row"/>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                    <TextBlock Text="KV Cache Type K" Classes="label"/>
                    <TextBox Text="{Binding KvCacheTypeK}" Watermark="e.g., f16, q8_0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="KV Cache Type V" Classes="label"/>
                    <TextBox Text="{Binding KvCacheTypeV}" Watermark="e.g., f16, q8_0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <CheckBox Content="Enable KV Offload to GPU" IsChecked="{Binding EnableKvOffload}"/>
                    <CheckBox Content="Enable Flash Attention" IsChecked="{Binding EnableFlashAttention}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Sampling Settings -->
            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Sampling Parameters" Classes="sectionHeader"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,12">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Temperature" Classes="label"/>
                    <TextBox Text="{Binding SamplingTemperature, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.7"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Top P" Classes="label"/>
                    <TextBox Text="{Binding TopP, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.9"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Top K" Classes="label"/>
                    <TextBox Text="{Binding TopK, Converter={StaticResource NullableValue}}" Watermark="e.g., 40"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Min P" Classes="label"/>
                    <TextBox Text="{Binding MinP, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.05"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Repeat Penalty" Classes="label"/>
                    <TextBox Text="{Binding RepeatPenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 1.1"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Repeat Last N" Classes="label"/>
                    <TextBox Text="{Binding RepeatLastNTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 64"/>
                  </StackPanel>
                  <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Presence Penalty" Classes="label"/>
                    <TextBox Text="{Binding PresencePenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Frequency Penalty" Classes="label"/>
                    <TextBox Text="{Binding FrequencyPenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.0"/>
                  </StackPanel>
                  <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <TextBlock Text="Random Seed (-1 for random)" Classes="label"/>
                    <TextBox Text="{Binding Seed, Converter={StaticResource NullableValue}}" Watermark="e.g., -1"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Threading & Memory -->
            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Threading &amp; Memory" Classes="sectionHeader"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,12">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <TextBlock Text="CPU Threads" Classes="label"/>
                    <TextBox Text="{Binding ThreadCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 8"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <CheckBox Content="Lock Model in Memory (Mlock)" IsChecked="{Binding EnableMlock}"/>
                    <CheckBox Content="Memory-map Model File (Mmap)" IsChecked="{Binding EnableMmap}"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Model Behavior & Logging -->
            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Model Behavior &amp; Logging" Classes="sectionHeader"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,12">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Chat Template" Classes="label"/>
                    <TextBox Text="{Binding ChatTemplate}" Watermark="e.g., llama-2"/>
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Model Alias" Classes="label"/>
                    <TextBox Text="{Binding ModelAlias}" Watermark="e.g., my-model"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Reasoning Format" Classes="label"/>
                    <TextBox Text="{Binding ReasoningFormat}" Watermark="e.g., chain-of-thought"/>
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Log Verbosity (0-3)" Classes="label"/>
                    <TextBox Text="{Binding LogVerbosity}" Watermark="e.g., 2"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                    <TextBlock Text="Reasoning Budget (tokens)" Classes="label"/>
                    <TextBox Text="{Binding ReasoningBudget, Converter={StaticResource NullableValue}}" Watermark="e.g., 1024"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                    <TextBlock Text="Reasoning Budget Message" Classes="label"/>
                    <TextBox Text="{Binding ReasoningBudgetMessage}" Watermark="e.g., --wait, I've exhausted my reasoning budget. I must stick with this answer."/>
                  </StackPanel>
                  <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <CheckBox Content="Enable Jinja Template Processing" IsChecked="{Binding EnableJinja}"/>
                    <TextBlock Text="Server Timeout (seconds)" Classes="label" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ServerTimeoutSeconds, Converter={StaticResource NullableValue}}" Watermark="e.g., 300"/>
                    <TextBlock Text="Extra Llama-Server Args" Classes="label" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ExtraLlamaArgs}" Watermark="e.g., -ts 14,38" AcceptsReturn="False"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
          <!-- Step 2: Pipeline Selection -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PipelineSelection}}">
            <TextBlock Text="Pipeline Selection" Classes="stepTitle"/>
            <TextBlock Text="Select the evaluation pipeline type that matches your use case."
                       Classes="helpText" Margin="0,0,0,16"/>

            <TextBlock Text="Pipeline Type" Classes="label"/>
            <ComboBox SelectedIndex="{Binding SelectedPipelineIndex}" HorizontalAlignment="Left" MinWidth="200">
              <ComboBoxItem Content="CasualQA"/>
              <ComboBoxItem Content="Translation"/>
              <ComboBoxItem Content="CSharpCoding"/>
            </ComboBox>

            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Pipeline Descriptions" Classes="sectionHeader"/>
                
                <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=CasualQA}" 
                        Background="#13131F" CornerRadius="4" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="CasualQA" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Evaluates casual conversational Q&amp;A — open-ended questions scored by LLM-as-judge for semantic accuracy." 
                               TextWrapping="Wrap" Foreground="#A6ADC8"/>
                  </StackPanel>
                </Border>
                
                <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}" 
                        Background="#13131F" CornerRadius="4" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Translation" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Evaluates language translation quality using LLM-as-judge for accuracy scoring." 
                               TextWrapping="Wrap" Foreground="#A6ADC8"/>
                  </StackPanel>
                </Border>
                
                <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=CSharpCoding}" 
                        Background="#13131F" CornerRadius="4" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="CSharpCoding" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Evaluates C# code generation quality by compiling the output and running unit tests." 
                               TextWrapping="Wrap" Foreground="#A6ADC8"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
          <!-- Step 3: Evaluation Dataset -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.EvaluationDataset}}">
            <TextBlock Text="Evaluation Dataset" Classes="stepTitle"/>
            <TextBlock Text="Configure your evaluation dataset source."
                       Classes="helpText" Margin="0,0,0,16"/>

            <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,8">
              <StackPanel Spacing="12">
                <TextBlock Text="Data Source" Classes="sectionHeader"/>
                <StackPanel Spacing="8">
                  <RadioButton Content="Single data file (JSON/JSONL/YAML/CSV/Parquet)"
                               IsChecked="{Binding UseSingleFileDataSource, Mode=TwoWay}"
                               GroupName="dataSource"/>
                  <StackPanel IsVisible="{Binding UseSingleFileDataSource}" Margin="20,4,0,0" Spacing="8">
                    <TextBox Text="{Binding DataFilePath}" Watermark="Select a data file..."/>
                    <Button Content="Browse..." HorizontalAlignment="Left" Padding="16,6"
                            Command="{Binding BrowseDataFileCommand}"/>
                  </StackPanel>

                  <RadioButton Content="Prompt/Expected directories"
                               IsChecked="{Binding UseDirectoryDataSource, Mode=TwoWay}"
                               GroupName="dataSource" Margin="0,8,0,0"/>
                  <StackPanel IsVisible="{Binding UseDirectoryDataSource}" Margin="20,4,0,0" Spacing="8">
                    <TextBox Text="{Binding PromptDir}" Watermark="Prompt directory path..."/>
                    <Button Content="Browse..." HorizontalAlignment="Left" Padding="16,6"
                            Command="{Binding BrowsePromptDirCommand}"/>
                    <TextBox Text="{Binding ExpectedDir}" Watermark="Expected output directory path (optional)" Margin="0,8,0,0"/>
                    <Button Content="Browse..." HorizontalAlignment="Left" Padding="16,6"
                            Command="{Binding BrowseExpectedDirCommand}"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 4: Field Mapping -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.FieldMapping}}">
            <TextBlock Text="Field Mapping" Classes="stepTitle"/>
            <TextBlock Text="Map fields from your input files to the evaluation pipeline."
                       Classes="helpText" Margin="0,0,0,16"/>

            <Border Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="Standard Field Mappings" Classes="sectionHeader"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                  <Run Text="Select or type field names from your data file. " Foreground="#A6ADC8"/>
                  <Run Text="Fields are auto-detected when you select a file." Foreground="#6C7086" FontStyle="Italic"/>
                </TextBlock>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="ID Field:" Classes="label" VerticalAlignment="Center"/>
                  <ComboBox Grid.Row="0" Grid.Column="1" 
                            Text="{Binding FieldMappingId}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,0,0,0"
                            IsEditable="True">
                    <ComboBox.Tag>Field name for item ID (optional)</ComboBox.Tag>
                  </ComboBox>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="User Prompt Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                  <ComboBox Grid.Row="1" Grid.Column="1" 
                            Text="{Binding FieldMappingUserPrompt}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"/>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Expected Output Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                  <ComboBox Grid.Row="2" Grid.Column="1" 
                            Text="{Binding FieldMappingExpectedOutput}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="System Prompt Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                  <ComboBox Grid.Row="3" Grid.Column="1" 
                            Text="{Binding FieldMappingSystemPrompt}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"/>

                  <!-- Translation pipeline per-item language fields -->
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Source Language Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"
                             IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}"/>
                  <ComboBox Grid.Row="4" Grid.Column="1" 
                            Text="{Binding FieldMappingSourceLanguage}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"
                            IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}"/>

                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Target Language Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"
                             IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}"/>
                  <ComboBox Grid.Row="5" Grid.Column="1" 
                            Text="{Binding FieldMappingTargetLanguage}" 
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"
                            IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}"/>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 6: Scoring -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.Scoring}}">
            <TextBlock Text="Scoring Configuration" Classes="stepTitle"/>
            <TextBlock Text="Configure LLM-as-judge for automated scoring of evaluation results."
                       Classes="helpText" Margin="0,0,0,16"/>

            <CheckBox Content="Enable LLM-as-Judge" IsChecked="{Binding EnableJudge, Mode=TwoWay}" Margin="0,8"/>

            <Border IsVisible="{Binding EnableJudge}" Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="Judge Server" Classes="sectionHeader"/>
                <TextBlock Text="Choose how to run the judge llama-server - either manage it locally or connect to an existing instance."
                           Classes="helpText" Margin="0,0,0,16"/>

                <StackPanel Spacing="12">
                  <RadioButton Content="Manage judge server locally"
                               IsChecked="{Binding JudgeManageServer}"
                               GroupName="judgeServerMode" Margin="0,4"/>
                  <RadioButton Content="Connect to existing judge server"
                               IsChecked="{Binding JudgeManageServer, Converter={x:Static convert:BoolNegationConverter.Instance}}"
                               GroupName="judgeServerMode" Margin="0,4"/>
                </StackPanel>

                <!-- Managed Judge Server -->
                <Border IsVisible="{Binding JudgeManageServer}" Background="#13131F" CornerRadius="6" Padding="16" Margin="0,8">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Judge Server Executable (optional)" Classes="subSectionHeader"/>
                    <TextBlock Text="Path to local llama-server executable for the judge. If not specified, uses the same as the primary server." Foreground="#7F849C" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBox Grid.Column="0" Text="{Binding JudgeExecutablePath}" Watermark="Path to judge llama-server executable (optional)..."/>
                      <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Padding="16,6"
                              Command="{Binding BrowseJudgeModelCommand}" CommandParameter="executable"/>
                    </Grid>

                    <Separator Background="#45475A" Margin="0,8"/>

                    <TextBlock Text="Judge Model Source" Classes="subSectionHeader"/>
                    <StackPanel Spacing="8">
                      <RadioButton Content="Local model file" IsChecked="{Binding JudgeUseLocalFile}" GroupName="judgeModelSource"/>
                      <StackPanel IsVisible="{Binding JudgeUseLocalFile}" Margin="20,4,0,0" Spacing="8">
                        <TextBlock Text="Judge Model File Path" Classes="label"/>
                        <TextBox Text="{Binding JudgeLocalModelPath}" Watermark="Select a .gguf model file for the judge..."/>
                        <Button Content="Browse..." HorizontalAlignment="Left" Padding="16,6"
                                Command="{Binding BrowseJudgeModelCommand}"/>
                      </StackPanel>

                      <RadioButton Content="Download from HuggingFace" IsChecked="{Binding JudgeUseLocalFile, Converter={x:Static convert:BoolNegationConverter.Instance}}" GroupName="judgeModelSource" Margin="0,8,0,0"/>
                      <StackPanel IsVisible="{Binding JudgeUseLocalFile, Converter={x:Static convert:BoolNegationConverter.Instance}}" Margin="20,4,0,0" Spacing="8">
                        <TextBlock Text="HuggingFace Repo" Classes="label"/>
                        <TextBox Text="{Binding JudgeHfRepo}" Watermark="e.g., TheBloke/Mistral-7B-Instruct-v0.1-GGUF"/>
                        <TextBlock Text="HuggingFace Token (optional)" Classes="label" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding JudgeHfToken}" Watermark="hf_..." PasswordChar="*"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Judge Performance Settings -->
                    <TextBlock Text="Judge Performance Settings" Classes="subSectionHeader" Margin="0,8,0,0"/>

                    <!-- Context & Batching -->
                    <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,4">
                      <StackPanel Spacing="8">
                        <TextBlock Text="Context &amp; Batching" Classes="label"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Context Window (tokens)" Classes="label"/>
                            <TextBox Text="{Binding JudgeContextWindowTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 4096"/>
                          </StackPanel>
                          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Parallel Slots" Classes="label"/>
                            <TextBox Text="{Binding JudgeParallelSlotCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 2"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Batch Size (tokens)" Classes="label"/>
                            <TextBox Text="{Binding JudgeBatchSizeTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 512"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Micro-Batch Size (tokens)" Classes="label"/>
                            <TextBox Text="{Binding JudgeUbatchSizeTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 64"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <CheckBox Content="Enable Continuous Batching" IsChecked="{Binding JudgeEnableContinuousBatching}"/>
                            <CheckBox Content="Cache Prompt Processing" IsChecked="{Binding JudgeEnableCachePrompt}"/>
                            <CheckBox Content="Enable Context Shift" IsChecked="{Binding JudgeEnableContextShift}"/>
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- GPU Settings -->
                    <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,4">
                      <StackPanel Spacing="8">
                        <TextBlock Text="GPU Acceleration" Classes="label"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="GPU Layers" Classes="label"/>
                            <TextBox Text="{Binding JudgeGpuLayerCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 32"/>
                          </StackPanel>
                          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Split Mode" Classes="label"/>
                            <ComboBox SelectedItem="{Binding JudgeSplitMode}" HorizontalAlignment="Left" MinWidth="150">
                              <ComboBoxItem Content="none"/>
                              <ComboBoxItem Content="layer"/>
                              <ComboBoxItem Content="row"/>
                            </ComboBox>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock Text="KV Cache Type K" Classes="label"/>
                            <TextBox Text="{Binding JudgeKvCacheTypeK}" Watermark="e.g., f16, q8_0"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="KV Cache Type V" Classes="label"/>
                            <TextBox Text="{Binding JudgeKvCacheTypeV}" Watermark="e.g., f16, q8_0"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <CheckBox Content="Enable KV Offload to GPU" IsChecked="{Binding JudgeEnableKvOffload}"/>
                            <CheckBox Content="Enable Flash Attention" IsChecked="{Binding JudgeEnableFlashAttention}"/>
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- Sampling Settings -->
                    <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,4">
                      <StackPanel Spacing="8">
                        <TextBlock Text="Sampling Parameters" Classes="label"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Temperature" Classes="label"/>
                            <TextBox Text="{Binding JudgeSamplingTemperature, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.7"/>
                          </StackPanel>
                          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Top P" Classes="label"/>
                            <TextBox Text="{Binding JudgeTopP, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.9"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Top K" Classes="label"/>
                            <TextBox Text="{Binding JudgeTopK, Converter={StaticResource NullableValue}}" Watermark="e.g., 40"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Min P" Classes="label"/>
                            <TextBox Text="{Binding JudgeMinP, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.05"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Repeat Penalty" Classes="label"/>
                            <TextBox Text="{Binding JudgeRepeatPenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 1.1"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Repeat Last N" Classes="label"/>
                            <TextBox Text="{Binding JudgeRepeatLastNTokens, Converter={StaticResource NullableValue}}" Watermark="e.g., 64"/>
                          </StackPanel>
                          <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Presence Penalty" Classes="label"/>
                            <TextBox Text="{Binding JudgePresencePenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.0"/>
                          </StackPanel>
                          <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Frequency Penalty" Classes="label"/>
                            <TextBox Text="{Binding JudgeFrequencyPenalty, Converter={StaticResource NullableValue}}" Watermark="e.g., 0.0"/>
                          </StackPanel>
                          <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <TextBlock Text="Random Seed (-1 for random)" Classes="label"/>
                            <TextBox Text="{Binding JudgeSeed, Converter={StaticResource NullableValue}}" Watermark="e.g., -1"/>
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- Threading & Memory -->
                    <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,4">
                      <StackPanel Spacing="8">
                        <TextBlock Text="Threading &amp; Memory" Classes="label"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="CPU Threads" Classes="label"/>
                            <TextBox Text="{Binding JudgeThreadCount, Converter={StaticResource NullableValue}}" Watermark="e.g., 8"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <CheckBox Content="Lock Model in Memory (Mlock)" IsChecked="{Binding JudgeEnableMlock}"/>
                            <CheckBox Content="Memory-map Model File (Mmap)" IsChecked="{Binding JudgeEnableMmap}"/>
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <!-- Model Behavior & Logging -->
                    <Border Background="#181825" CornerRadius="6" Padding="12" Margin="0,4">
                      <StackPanel Spacing="8">
                        <TextBlock Text="Model Behavior &amp; Logging" Classes="label"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Chat Template" Classes="label"/>
                            <TextBox Text="{Binding JudgeChatTemplate}" Watermark="e.g., llama-2"/>
                          </StackPanel>
                          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Model Alias" Classes="label"/>
                            <TextBox Text="{Binding JudgeModelAlias}" Watermark="e.g., my-model"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Reasoning Format" Classes="label"/>
                            <TextBox Text="{Binding JudgeReasoningFormat}" Watermark="e.g., chain-of-thought"/>
                          </StackPanel>
                          <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Log Verbosity (0-3)" Classes="label"/>
                            <TextBox Text="{Binding JudgeLogVerbosity}" Watermark="e.g., 2"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Reasoning Budget (tokens)" Classes="label"/>
                            <TextBox Text="{Binding JudgeReasoningBudget, Converter={StaticResource NullableValue}}" Watermark="e.g., 1024"/>
                          </StackPanel>
                          <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Reasoning Budget Message" Classes="label"/>
                            <TextBox Text="{Binding JudgeReasoningBudgetMessage}" Watermark="e.g., --wait, I've exhausted my reasoning budget. I must stick with this answer."/>
                          </StackPanel>
                          <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                            <CheckBox Content="Enable Jinja Template Processing" IsChecked="{Binding JudgeEnableJinja}"/>
                            <TextBlock Text="Server Timeout (seconds)" Classes="label" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding JudgeServerTimeoutSeconds, Converter={StaticResource NullableValue}}" Watermark="e.g., 300"/>
                            <TextBlock Text="Extra Judge Llama-Server Args" Classes="label" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding JudgeExtraLlamaArgs}" Watermark="e.g., -ts 14,38" AcceptsReturn="False"/>
                          </StackPanel>
                        </Grid>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <!-- External Judge Server -->
                <Border IsVisible="{Binding !JudgeManageServer}" Background="#13131F" CornerRadius="6" Padding="16" Margin="0,8">
                  <StackPanel Spacing="12">
                    <TextBlock Text="Judge Server Connection" Classes="subSectionHeader"/>
                    <TextBlock Text="Judge Server URL" Classes="label"/>
                    <TextBox Text="{Binding JudgeServerUrl}" Watermark="http://127.0.0.1:8081"/>
                    <Button Content="Test Connection" HorizontalAlignment="Left" Padding="16,6" Margin="0,8"
                            Command="{Binding TestJudgeConnectionCommand}"/>
                  </StackPanel>
                </Border>

                <Separator Background="#45475A" Margin="0,8"/>

                <TextBlock Text="Scoring Settings" Classes="sectionHeader"/>
                <TextBlock Text="Judge Template" Classes="label" Margin="0,8,0,0"/>
                <ComboBox SelectedIndex="{Binding SelectedJudgeTemplateIndex}" HorizontalAlignment="Left" MinWidth="200">
                  <ComboBoxItem Content="casual-q-a-judge-template"/>
                  <ComboBoxItem Content="code-quality-judge-template"/>
                  <ComboBoxItem Content="pass-fail"/>
                  <ComboBoxItem Content="standard"/>
                  <ComboBoxItem Content="structured-json"/>
                  <ComboBoxItem Content="translation-judge-template"/>
                </ComboBox>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 7: Output -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.Output}}">
            <TextBlock Text="Output Configuration" Classes="stepTitle"/>
            <TextBlock Text="Configure where results are saved and export options."
                       Classes="helpText" Margin="0,0,0,16"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Output Directory:" Classes="label" VerticalAlignment="Center"/>
              <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding OutputDir}"/>
                <Button Grid.Column="1" Content="Browse..." Padding="16,6"
                        Command="{Binding BrowseOutputDirCommand}"/>
              </Grid>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Run Name:" Classes="label" VerticalAlignment="Center"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RunName}" Watermark="My evaluation run"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Shell Dialect:" Classes="label" VerticalAlignment="Center"/>
              <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Bash" GroupName="shell" IsChecked="{Binding ShellTarget, Converter={x:Static convert:ShellTargetConverter.Instance}, ConverterParameter=Bash}"/>
                <RadioButton Content="PowerShell" GroupName="shell" IsChecked="{Binding ShellTarget, Converter={x:Static convert:ShellTargetConverter.Instance}, ConverterParameter=PowerShell}"/>
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- Step 8: Pipeline Configuration (moved to end) -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.PipelineConfiguration}}">
            <TextBlock Text="Pipeline Configuration" Classes="stepTitle"/>
            <TextBlock Text="Configure pipeline-specific options."
                       Classes="helpText" Margin="0,0,0,16"/>

            <!-- Translation Pipeline Config -->
            <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=Translation}">
              <Border IsVisible="{Binding ShouldHideGlobalTranslationSettings, Converter={x:Static convert:BoolNegationConverter.Instance}}"
                      Background="#181825" CornerRadius="6" Padding="16">
                <StackPanel Spacing="12">
                  <TextBlock Text="Translation Settings" Classes="sectionHeader"/>
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Language:" Classes="label" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TranslationSourceLanguage}" Watermark="e.g., English" Margin="12,0,0,0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Target Language:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TranslationTargetLanguage}" Watermark="e.g., French" Margin="12,8,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="System Prompt:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TranslationSystemPrompt}"
                             Watermark="Custom system prompt for translation (optional)"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" Margin="12,8,0,0"/>
                  </Grid>
                </StackPanel>
              </Border>
            </Border>

            <!-- C# Coding Pipeline Config -->
            <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=CSharpCoding}"
                    Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="C# Coding Settings" Classes="sectionHeader"/>

                <TextBlock Text="Field Mappings" Classes="subSectionHeader" Margin="0,8,0,4"/>
                <TextBlock Text="Specify the field names in your data file that contain test file and build script paths."
                           Foreground="#7F849C" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Test File Field:" Classes="label" VerticalAlignment="Center"/>
                  <ComboBox Grid.Row="0" Grid.Column="1"
                            Text="{Binding FieldMappingTestFile}"
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,0,0,0"
                            IsEditable="True"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Build Script Field:" Classes="label" VerticalAlignment="Center" Margin="0,8,0,0"/>
                  <ComboBox Grid.Row="1" Grid.Column="1"
                            Text="{Binding FieldMappingBuildScript}"
                            ItemsSource="{Binding DetectedFields}"
                            Margin="12,8,0,0"
                            IsEditable="True"/>
                </Grid>

                <Separator Background="#45475A" Margin="0,16"/>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="0,8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Build Script:" Classes="label" VerticalAlignment="Center"/>
                  <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="12,0,0,0">
                    <TextBox Grid.Column="0" Text="{Binding CodeBuildScriptPath}" Watermark="Path to custom build script (optional)"/>
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Padding="16,6"
                            Command="{Binding BrowseBuildScriptCommand}"/>
                  </Grid>
                </Grid>
              </StackPanel>
            </Border>

            <!-- No pipeline-specific config message -->
            <Border IsVisible="{Binding PipelineName, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter=CasualQA}"
                    Background="#181825" CornerRadius="6" Padding="16">
              <StackPanel Spacing="12">
                <TextBlock Text="CasualQA Settings" Classes="sectionHeader"/>
                <TextBlock Text="The CasualQA pipeline has no pipeline-specific settings."
                           Foreground="#7F849C" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Step 9: Review & Run -->
          <StackPanel Spacing="16" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ReviewAndRun}}">
            <TextBlock Text="Review &amp; Run" Classes="stepTitle"/>
            <TextBlock Text="Review your configuration below. Export as settings or script, then run the evaluation."
                       Classes="helpText" Margin="0,0,0,8"/>

            <TextBlock Text="Configuration Preview (YAML)" Classes="sectionHeader"/>
            <Border Background="#0D0D14" CornerRadius="4" Padding="12">
              <TextBox Text="{Binding ConfigYamlPreview}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="NoWrap"
                       FontFamily="Consolas,Monaco,monospace"
                       FontSize="12"
                       Background="Transparent"
                       BorderThickness="0"
                       Foreground="#A6ADC8"/>
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>

    <!-- Navigation Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
		<Button Content="Export as Settings" Classes="secondary" Padding="24,10" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ReviewAndRun}}"
		      Command="{Binding ExportSettingsCommand}"/>
		<Button Content="Export as Script" Classes="secondary" Padding="24,10" IsVisible="{Binding CurrentStep, Converter={x:Static convert:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:WizardStepKind.ReviewAndRun}}"
		      Command="{Binding ExportScriptCommand}"/>

		<Button Content="← Back" Classes="secondary" Padding="20,8"
              IsVisible="{Binding CanGoBack}"
              Command="{Binding GoBackCommand}"/>
      <Button Content="Next →" Classes="primary" Padding="20,8"
              IsEnabled="{Binding CanGoForward}"
              Command="{Binding GoForwardCommand}"/>
    </StackPanel>
  </Grid>
</UserControl>
