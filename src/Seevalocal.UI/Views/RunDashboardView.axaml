<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Seevalocal.UI.ViewModels"
             xmlns:local="using:Seevalocal.UI"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="Seevalocal.UI.Views.RunDashboardView"
             x:DataType="vm:MainWindowViewModel">

  <Grid RowDefinitions="Auto,*,Auto">
    <TextBlock Text="Run Dashboard" Classes="pageTitle" Grid.Row="0"/>

    <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="8" Padding="16" Margin="0,16">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <StackPanel Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center"
                      IsVisible="{Binding ActiveRun, Converter={x:Static local:IsNullConverter.Instance}}">
            <TextBlock Text="No active run" FontSize="24" Foreground="#7F849C" HorizontalAlignment="Center"/>
            <TextBlock Text="Start a new evaluation from the Setup Wizard" FontSize="14" Foreground="#6C7086" HorizontalAlignment="Center"/>
            <Button Content="Open Setup Wizard" Classes="primary" Padding="24,10" HorizontalAlignment="Center" Margin="0,16"
                    Command="{Binding NavigateToWizardCommand}"/>
          </StackPanel>

          <!-- Active Run Display -->
          <StackPanel Spacing="16"
                      IsVisible="{Binding ActiveRun, Converter={x:Static local:IsNullConverter.Instance}, ConverterParameter=Invert}">
            
            <!-- Status Header -->
            <TextBlock Text="{Binding ActiveRun.StatusLine}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>

            <!-- Progress Bar -->
            <ProgressBar Value="{Binding ActiveRun.ProgressPercent}" Maximum="100" Height="24" Margin="0,8"/>

            <!-- Stats Grid -->
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" Margin="0,8">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Completed" Foreground="#7F849C" FontSize="12"/>
                <TextBlock FontSize="18">
                  <Run Text="{Binding ActiveRun.CompletedCount}"/>
                  <Run Text=" / "/>
                  <Run Text="{Binding ActiveRun.TotalCount}"/>
                </TextBlock>
              </StackPanel>

              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Tokens/sec" Foreground="#7F849C" FontSize="12"/>
                <TextBlock Text="{Binding ActiveRun.AverageTokensPerSecond, StringFormat={}{0:F1}}" FontSize="18"/>
              </StackPanel>

              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="ETA" Foreground="#7F849C" FontSize="12"/>
                <TextBlock FontSize="18">
                  <Run Text="{Binding ActiveRun.EstimatedRemainingSeconds, StringFormat={}{0:F0}}"/>
                  <Run Text="s"/>
                </TextBlock>
              </StackPanel>

              <StackPanel Grid.Column="3" Spacing="4">
                <TextBlock Text="Recent Activity" Foreground="#7F849C" FontSize="12"/>
                <TextBlock Text="{Binding ActiveRun.RecentActivitySummary}" FontSize="12" TextTrimming="CharacterEllipsis"/>
              </StackPanel>
            </Grid>

            <!-- Recent Completions (First 10 with full details) -->
            <Border Background="#13131F" CornerRadius="6" Padding="12" Margin="0,8">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="Recent Completions (First 10)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" Height="400" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding ActiveRun.RecentCompletions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#1E1E2E" CornerRadius="4" Padding="12" Margin="0,2">
                            <StackPanel Spacing="8">
                              <!-- Header Row -->
                              <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Status Badge -->
                                <Border Grid.Column="0" 
                                        Background="{Binding Succeeded, Converter={x:Static local:StatusToBackgroundConverter.Instance}}"
                                        CornerRadius="3" Padding="8,4" Margin="0,0,8,0">
                                  <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                
                                <!-- ID -->
                                <TextBlock Grid.Column="1" Text="{Binding Id}" FontSize="12" VerticalAlignment="Center" 
                                           Foreground="#A6ADC8" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Duration -->
                                <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, StringFormat={}{0:F2}s}"
                                           Foreground="#7F849C" FontSize="12" VerticalAlignment="Center"/>
                              </Grid>

                              <!-- Prompt Section -->
                              <Border Background="#1A1A2E" CornerRadius="4" Padding="10">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="Prompt:" FontSize="11" Foreground="#7F849C" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding UserPrompt}" TextWrapping="Wrap" FontSize="12" 
                                             Foreground="#CDD6F4"/>
                                </StackPanel>
                              </Border>

                              <!-- Response Section -->
                              <Border Background="#1A1A2E" CornerRadius="4" Padding="10">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="Response:" FontSize="11" Foreground="#7F849C" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding RawResponse}" TextWrapping="Wrap" FontSize="12" 
                                             Foreground="#A6E3A1"/>
                                </StackPanel>
                              </Border>

                              <!-- Expected Output (if available) -->
                              <Border Background="#1A1A2E" CornerRadius="4" Padding="10"
                                      IsVisible="{Binding ExpectedOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="Expected:" FontSize="11" Foreground="#7F849C" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding ExpectedOutput}" TextWrapping="Wrap" FontSize="12" 
                                             Foreground="#F9E2AF"/>
                                </StackPanel>
                              </Border>

                              <!-- Judge Score (if available) -->
                              <Border Background="#1A1A2E" CornerRadius="4" Padding="10"
                                      IsVisible="{Binding JudgeScore, Converter={x:Static local:IsNotNullConverter.Instance}}">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="Judge Score:" FontSize="11" Foreground="#7F849C" FontWeight="SemiBold"/>
                                  <TextBlock FontSize="14" FontWeight="SemiBold">
                                    <Run Text="{Binding JudgeScore, StringFormat={}{0:F1}}"/>
                                    <Run Text="/10" Foreground="#7F849C"/>
                                  </TextBlock>
                                </StackPanel>
                              </Border>

                              <!-- Judge Rationale (if available) -->
                              <Border Background="#1A1A2E" CornerRadius="4" Padding="10"
                                      IsVisible="{Binding JudgeRationale, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="Judge Rationale:" FontSize="11" Foreground="#7F849C" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding JudgeRationale}" TextWrapping="Wrap" FontSize="12" 
                                             Foreground="#F5C2E7"/>
                                </StackPanel>
                              </Border>

                              <!-- Metrics Tags -->
                              <WrapPanel>
                                <ItemsControl ItemsSource="{Binding MetricDisplay}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <Border Background="#2A2A3E" CornerRadius="3" Padding="6,3" Margin="0,0,4,0">
                                        <TextBlock FontSize="10" Foreground="#9399B2">
                                          <Run Text="{Binding Name}" Foreground="#7F849C"/>
                                          <Run Text=": "/>
                                          <Run Text="{Binding Value}" Foreground="#CDD6F4"/>
                                        </TextBlock>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </WrapPanel>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>

            <!-- All Results Summary (compact) -->
            <Border Background="#13131F" CornerRadius="6" Padding="12" Margin="0,8"
                    IsVisible="{Binding ActiveRun.Results.Count, Converter={x:Static local:IsGreaterThan10Converter.Instance}}">
              <Grid RowDefinitions="Auto">
                <TextBlock Grid.Row="0" Text="All Results (showing first 10 above, see Results tab for all)" 
                           FontSize="12" Foreground="#7F849C" FontStyle="Italic"/>
              </Grid>
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>

    <!-- Control Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
      <Button Content="Pause" Classes="secondary" Padding="16,8"
              IsEnabled="{Binding ActiveRun.IsRunning}"
              Command="{Binding ActiveRun.PauseCommand}"/>
      <Button Content="Cancel Run" Classes="danger" Padding="16,8"
              IsEnabled="{Binding ActiveRun.IsRunning}"
              Command="{Binding ActiveRun.CancelCommand}"/>
    </StackPanel>
  </Grid>
</UserControl>
