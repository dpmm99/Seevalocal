<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Seevalocal.UI.ViewModels"
        xmlns:views="using:Seevalocal.UI.Views"
        xmlns:local="using:Seevalocal.UI"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Seevalocal.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding TitleBarText}"
        Width="1200" Height="700"
        Background="#181825" Foreground="#CDD6F4">

  <Window.Styles>
    <!-- Sidebar button style -->
    <Style Selector="Button.navButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#BAC2E8"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="4,2"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="Button.navButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#313244"/>
    </Style>
    <Style Selector="Button.navButton.active">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#89B4FA"/>
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="200,*">
    <!-- Sidebar Navigation -->
    <Border Grid.Column="0" Background="#1E1E2E" Padding="8">
      <StackPanel Spacing="4">
        <TextBlock Text="Seevalocal" FontSize="20" FontWeight="Bold" 
                   Foreground="#89B4FA" Margin="0,8,0,16"/>
        
        <Button Classes="navButton" 
                Classes.active="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Wizard}}"
                Command="{Binding NavigateToWizardCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="📝" FontSize="16"/>
            <TextBlock Text="Setup Wizard" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        
        <Button Classes="navButton"
                Classes.active="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.RunDashboard}}"
                Command="{Binding NavigateToDashboardCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="▶️" FontSize="16"/>
            <TextBlock Text="Run Dashboard" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        
        <Button Classes="navButton"
                Classes.active="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Results}}"
                Command="{Binding NavigateToResultsCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="📊" FontSize="16"/>
            <TextBlock Text="Results Viewer" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        
        <Button Classes="navButton"
                Classes.active="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Settings}}"
                Command="{Binding NavigateToSettingsCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="⚙️" FontSize="16"/>
            <TextBlock Text="Settings" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Separator Margin="0,16,0,8" Background="#45475A"/>
        
        <!-- Settings file stack -->
        <TextBlock Text="Settings Stack" FontSize="12" Foreground="#7F849C" Margin="0,8,0,4"/>
        <ItemsControl ItemsSource="{Binding SettingsLayers}" Margin="0,0,0,8">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2">
                <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="#BAC2E8" 
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <Button Content="+ Add Settings File"
                HorizontalAlignment="Stretch"
                Background="#313244" Foreground="#CDD6F4"
                Padding="8,6" CornerRadius="4"
                Command="{Binding AddSettingsFileCommand}"/>
      </StackPanel>
    </Border>

    <!-- Main Content Area -->
    <Border Grid.Column="1" Padding="16">
      <Grid RowDefinitions="*">
        <!-- Wizard View -->
        <views:WizardView Grid.Row="0" x:Name="WizardView"
                          IsVisible="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Wizard}}"/>

        <!-- Run Dashboard View -->
        <views:RunDashboardView Grid.Row="0" x:Name="RunDashboardView"
            IsVisible="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.RunDashboard}}"/>

        <!-- Results View -->
        <views:ResultsView Grid.Row="0" x:Name="ResultsView"
            IsVisible="{Binding CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Results}}"/>

        <!-- Settings View -->
        <views:SettingsView Grid.Row="0" x:Name="SettingsView"
            DataContext="{Binding SettingsViewModel}"
            IsVisible="{Binding $parent[Window].DataContext.CurrentView, Converter={x:Static local:IsEqualConverter.Instance}, ConverterParameter={x:Static vm:AppView.Settings}}"/>
      </Grid>
    </Border>
  </Grid>
</Window>
